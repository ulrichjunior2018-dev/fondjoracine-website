# Public site settings
NEXT_PUBLIC_APP_NAME="Maison Fondjo"
# Canonical site URL (SEO, emails, webhook absolute paths). Set per environment:
# - Local `.env.local` → http://localhost:3000
# - Vercel Production → https://fondjoracine.com
# Stripe *shopper return* URLs also use the request Origin when present, so
# local checkout returns to localhost even if this is briefly wrong — still set it.
NEXT_PUBLIC_SITE_URL="https://fondjoracine.com"

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ---------------------------------------------------------------------------
# Auth emails (signup confirm + password reset) — sent by SUPABASE, not Resend
# ---------------------------------------------------------------------------
# Resend in this repo is for order/admin notifications only. Account emails use
# Supabase Auth. If you see "email rate limit exceeded", that is Supabase's
# built-in mail limit — not your Resend dashboard quota.
#
# Fix (recommended for production):
# 1. Supabase → Project Settings → Authentication → URL Configuration
#    Site URL: https://fondjoracine.com   (NOT http://localhost:3000)
#    Redirect URLs (add all):
#      https://fondjoracine.com/auth/callback
#      https://fondjoracine.com/auth/callback/**
#      https://www.fondjoracine.com/auth/callback
#      http://localhost:3000/auth/callback   (local dev only)
# 2. Supabase → Authentication → Email → Custom SMTP (use Resend):
#    Host: smtp.resend.com | Port: 465 | User: resend
#    Password: your RESEND_API_KEY | Sender: RESEND_FROM_EMAIL (verified domain)
# 3. Vercel → Environment variables → NEXT_PUBLIC_SITE_URL=https://fondjoracine.com
#    Redeploy after changing env or Supabase URL settings.
# ---------------------------------------------------------------------------
# Identity / sign-in methods — SYSTEM-WIDE (src/lib/identity)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED="true"
# Future methods — leave false until dashboard + IdP are ready:
NEXT_PUBLIC_AUTH_APPLE_ENABLED="false"
NEXT_PUBLIC_AUTH_FACEBOOK_ENABLED="false"
NEXT_PUBLIC_AUTH_PHONE_ENABLED="false"
#
# Supabase → Authentication → URL Configuration → Redirect URLs must include:
#   http://localhost:3000/auth/callback
#   http://YOUR_LAN_IP:3000/auth/callback
#   https://fondjoracine.com/auth/callback
# Google Cloud authorized redirect URI must be:
#   https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback

# Customer accounts / WhatsApp / payments
NEXT_PUBLIC_WHATSAPP_NUMBER=""
# Legacy MoMo numbers — unused until a future Mobile Money provider is wired
MTN_MOMO_NUMBER=""
ORANGE_MONEY_NUMBER=""

# Admin notifications
# Admin notifications (new orders + payment confirmations via Resend)
ADMIN_EMAIL="admin@fondjoracine.com"
RESEND_API_KEY=""
RESEND_FROM_EMAIL="care@fondjoracine.com"
# Required for live order alerts: set RESEND_API_KEY and a verified RESEND_FROM_EMAIL domain.
# ADMIN_EMAIL receives every new storefront order (placed + confirmed).

# Stripe — Card (Visa / Mastercard). Optional until card checkout is enabled.
STRIPE_SECRET_KEY=""
STRIPE_HAIR_ELIXIR_PRICE_ID=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_STRIPE_PAYMENT_REQUEST_ENABLED="false"

# Cloudinary, optional for managed media uploads
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
