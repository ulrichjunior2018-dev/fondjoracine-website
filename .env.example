# Public site settings
NEXT_PUBLIC_APP_NAME="Maison Fondjo"
NEXT_PUBLIC_SITE_URL="https://fondjoracine.com"

# Supabase
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Customer accounts
# Set true only after Google OAuth is configured in the Supabase dashboard.
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED="false"

# WhatsApp and local payment numbers
# Use Cameroon E.164 format, for example +2376XXXXXXXX
NEXT_PUBLIC_WHATSAPP_NUMBER=""
MTN_MOMO_NUMBER=""
ORANGE_MONEY_NUMBER=""

# Admin notifications
ADMIN_EMAIL="admin@fondjoracine.com"
RESEND_API_KEY=""
RESEND_FROM_EMAIL="care@fondjoracine.com"

# Stripe, optional until card checkout is enabled
STRIPE_SECRET_KEY=""
STRIPE_HAIR_ELIXIR_PRICE_ID=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Set true only after Stripe Payment Request / wallet checkout is fully enabled.
NEXT_PUBLIC_STRIPE_PAYMENT_REQUEST_ENABLED="false"

# Cloudinary, optional for managed media uploads
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
